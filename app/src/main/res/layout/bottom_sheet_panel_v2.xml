<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 底部面板 BottomSheet -->
    <LinearLayout
        android:id="@+id/bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="?attr/colorSurface"
        android:elevation="8dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="48dp"
        app:behavior_hideable="false"
        app:behavior_fitToContents="false"
        app:behavior_halfExpandedRatio="0.5">

        <!-- 符号输入栏（默认显示，48dp高度） -->
        <com.wuxianggujun.tinaide.ui.SymbolInputBar
            android:id="@+id/symbol_input_bar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="?attr/colorSurfaceVariant"
            android:elevation="2dp" />

        <!-- Tab 导航栏 + LSP 状态（48dp高度） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="?attr/colorSurface">

            <!-- Tab 布局 -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_layout"
                style="@style/Widget.App.TabLayout"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:tabMode="fixed"
                app:tabGravity="fill"
                app:tabTextColor="?colorOnSurfaceVariant"
                app:tabSelectedTextColor="?colorPrimary"
                app:tabIndicatorColor="?colorPrimary"
                app:tabIndicatorHeight="3dp"
                app:tabMaxWidth="0dp"
                app:tabPaddingStart="8dp"
                app:tabPaddingEnd="8dp" />

            <!-- LSP 状态指示器 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <View
                    android:id="@+id/lsp_status_indicator"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/lsp_status_indicator"
                    android:backgroundTint="?attr/colorError" />

                <TextView
                    android:id="@+id/tv_lsp_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="LSP"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

        </LinearLayout>

        <!-- ViewPager2 用于 Tab 内容切换（占据剩余空间） -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/view_pager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
