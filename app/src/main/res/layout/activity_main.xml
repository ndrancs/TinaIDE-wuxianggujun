<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- 主内容区域 -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true">

        <!-- Toolbar -->
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/app_bar_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fitsSystemWindows="true"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="?attr/colorPrimary"
                app:popupTheme="@style/ThemeOverlay.Tina.ToolbarPopup.Dark" />

        </com.google.android.material.appbar.AppBarLayout>

        <!-- 主内容区域：编辑器和终端的分割布局 -->
        <LinearLayout
            android:id="@+id/content_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <!-- 编辑器区域 -->
            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/editor_container"
                android:name="com.wuxianggujun.tinaide.ui.fragment.EditorContainerFragment"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- 终端区域已移除 -->

            <!-- 输出工具栏 -->
            <LinearLayout
                android:id="@+id/output_toolbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="8dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:background="@android:color/darker_gray">

                <TextView
                    android:id="@+id/output_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="输出"
                    android:textColor="@android:color/white"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btn_output_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:contentDescription="输出详情/最近结果"
                    android:src="@android:drawable/ic_dialog_info" />
            </LinearLayout>

            <!-- 输出面板 -->
            <ScrollView
                android:id="@+id/output_scroll"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:fillViewport="true">
                <TextView
                    android:id="@+id/tv_output"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:background="#222222"
                    android:textIsSelectable="true"
                    android:padding="8dp"
                    android:textSize="12sp"
                    tools:text="=== 输出区 ===\n"/>
            </ScrollView>

        </LinearLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- 文件树侧边栏 -->
    <LinearLayout
        android:id="@+id/nav_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="?android:attr/colorBackground"
        android:fitsSystemWindows="true">

        <include layout="@layout/include_file_tree_header" />

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/file_tree_container"
            android:name="com.wuxianggujun.tinaide.ui.fragment.FileTreeFragment"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
