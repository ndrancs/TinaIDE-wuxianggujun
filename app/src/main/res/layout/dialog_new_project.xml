<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp">

        <!-- 项目名称输入 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_project_name"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/hint_project_name"
            app:boxStrokeColor="@color/text_input_box_stroke"
            app:hintTextColor="@color/dark_secondary"
            app:startIconDrawable="@drawable/ic_folder"
            app:startIconTint="@color/dark_secondary"
            app:errorEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_project_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/dark_on_surface"
                android:textCursorDrawable="@drawable/cursor_drawable" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- 项目路径输入 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_project_path"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/hint_project_path"
            app:boxStrokeColor="@color/text_input_box_stroke"
            app:hintTextColor="@color/dark_secondary"
            app:endIconMode="custom"
            app:endIconDrawable="@drawable/ic_folder"
            app:endIconTint="@color/dark_secondary"
            app:endIconContentDescription="@string/btn_choose_directory"
            app:errorEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_project_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/dark_on_surface"
                android:textCursorDrawable="@drawable/cursor_drawable" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- 项目类型选择 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_project_type"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/hint_project_type"
            app:boxStrokeColor="@color/text_input_box_stroke"
            app:hintTextColor="@color/dark_secondary"
            app:startIconDrawable="@drawable/ic_code"
            app:startIconTint="@color/dark_secondary">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/dropdown_project_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textColor="@color/dark_on_surface"
                android:textCursorDrawable="@drawable/cursor_drawable" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- 项目描述（可选） -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_project_description"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/hint_project_description"
            app:boxStrokeColor="@color/text_input_box_stroke"
            app:hintTextColor="@color/dark_secondary"
            app:counterEnabled="true"
            app:counterMaxLength="200">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_project_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:maxLines="4"
                android:textColor="@color/dark_on_surface"
                android:textCursorDrawable="@drawable/cursor_drawable" />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

</ScrollView>
