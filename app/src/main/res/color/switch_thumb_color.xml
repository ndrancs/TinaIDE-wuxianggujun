<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 选中且启用状态 - 主色 -->
    <item android:state_checked="true" android:state_enabled="true" android:color="@color/md_theme_primary" />
    <!-- 选中但禁用状态 - 半透明主色 -->
    <item android:state_checked="true" android:state_enabled="false" android:color="@color/md_theme_outlineVariant" />
    <!-- 未选中且启用状态 - outline -->
    <item android:state_enabled="true" android:color="@color/md_theme_outline" />
    <!-- 未选中且禁用状态 - outlineVariant -->
    <item android:color="@color/md_theme_outlineVariant" />
</selector>
