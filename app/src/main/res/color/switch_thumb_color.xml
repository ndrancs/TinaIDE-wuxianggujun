<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 选中且启用状态 - 青绿色 -->
    <item android:state_checked="true" android:state_enabled="true" android:color="@color/dark_secondary" />
    <!-- 选中但禁用状态 - 半透明青绿色 -->
    <item android:state_checked="true" android:state_enabled="false" android:color="#8003DAC6" />
    <!-- 未选中且启用状态 - 浅灰色 -->
    <item android:state_enabled="true" android:color="#BDBDBD" />
    <!-- 未选中且禁用状态 - 深灰色 -->
    <item android:color="#757575" />
</selector>
