<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 错误状态 -->
    <item android:color="@color/dark_error" android:state_focused="true" app:state_error="true" xmlns:app="http://schemas.android.com/apk/res-auto"/>
    <item android:color="@color/dark_error" app:state_error="true" xmlns:app="http://schemas.android.com/apk/res-auto"/>
    
    <!-- 聚焦状态 - 使用亮青色 -->
    <item android:color="@color/dark_secondary" android:state_focused="true"/>
    
    <!-- 激活状态（有内容时）- 使用青色的 70% 透明度 -->
    <item android:color="#B303DAC6" android:state_activated="true"/>
    
    <!-- 默认状态 - 使用青色的 50% 透明度 -->
    <item android:color="#8003DAC6"/>
</selector>
