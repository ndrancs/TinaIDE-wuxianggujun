<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <!-- 错误状态 -->
    <item android:color="@color/md_theme_error" android:state_focused="true" app:state_error="true"/>
    <item android:color="@color/md_theme_error" app:state_error="true"/>

    <!-- 聚焦状态 - 使用主色 -->
    <item android:color="@color/md_theme_primary" android:state_focused="true"/>

    <!-- 激活状态（有内容时）- 使用主色的 70% 透明度 -->
    <item android:color="#B303DAC6" android:state_activated="true"/>

    <!-- 默认状态 - 使用主色的 50% 透明度 -->
    <item android:color="#8003DAC6"/>
</selector>
