<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- 根设置列表：参照 CodeAssist，使用纯文本项 + fragment 跳转 -->

    <!-- 编辑器设置 -->
    <Preference
        android:key="editor"
        android:title="@string/settings_title_editor"
        android:summary="@string/settings_desc_editor"
        app:fragment="com.wuxianggujun.tinaide.settings.EditorPreferenceFragment"
        app:iconSpaceReserved="false" />

    <!-- 编译器设置 -->
    <Preference
        android:key="compiler"
        android:title="@string/settings_title_compiler"
        android:summary="@string/settings_desc_compiler"
        app:fragment="com.wuxianggujun.tinaide.settings.CompilerPreferenceFragment"
        app:iconSpaceReserved="false" />

    <!-- 项目设置 -->
    <Preference
        android:key="project"
        android:title="@string/settings_title_project"
        android:summary="@string/settings_desc_project"
        app:fragment="com.wuxianggujun.tinaide.settings.ProjectPreferenceFragment"
        app:iconSpaceReserved="false" />

    <!-- 外观设置 -->
    <Preference
        android:key="appearance"
        android:title="@string/settings_title_appearance"
        android:summary="@string/settings_desc_appearance"
        app:fragment="com.wuxianggujun.tinaide.settings.AppearancePreferenceFragment"
        app:iconSpaceReserved="false" />

    <!-- 关于 -->
    <Preference
        android:key="about"
        android:title="@string/settings_title_about"
        android:summary="@string/settings_desc_about"
        app:fragment="com.wuxianggujun.tinaide.settings.AboutPreferenceFragment"
        app:iconSpaceReserved="false" />

</PreferenceScreen>
