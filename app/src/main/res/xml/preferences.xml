<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- 编辑器设置 -->
    <PreferenceCategory
        android:title="编辑器"
        android:icon="@android:drawable/ic_menu_edit"
        app:iconSpaceReserved="false">

        <SeekBarPreference
            android:key="editor_font_size"
            android:title="字体大小"
            android:summary="调整编辑器字体大小"
            android:defaultValue="14"
            android:min="10"
            android:max="24"
            app:showSeekBarValue="true"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            android:key="editor_line_numbers"
            android:title="显示行号"
            android:summary="在编辑器左侧显示行号"
            android:defaultValue="true"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            android:key="editor_auto_indent"
            android:title="自动缩进"
            android:summary="按下回车键时自动缩进"
            android:defaultValue="true"
            app:iconSpaceReserved="false" />

        <ListPreference
            android:key="editor_tab_size"
            android:title="Tab 大小"
            android:summary="Tab 键对应的空格数"
            android:entries="@array/tab_size_entries"
            android:entryValues="@array/tab_size_values"
            android:defaultValue="4"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            android:key="editor_word_wrap"
            android:title="自动换行"
            android:summary="长行自动换行显示"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

        <ListPreference
            android:key="editor_theme"
            android:title="编辑器主题"
            android:summary="选择代码编辑器配色方案"
            android:entries="@array/editor_theme_entries"
            android:entryValues="@array/editor_theme_values"
            android:defaultValue="darcula"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- 编译器设置 -->
    <PreferenceCategory
        android:title="编译器"
        android:icon="@android:drawable/ic_menu_manage"
        app:iconSpaceReserved="false">

        <ListPreference
            android:key="compiler_optimization"
            android:title="优化级别"
            android:summary="编译优化等级"
            android:entries="@array/optimization_entries"
            android:entryValues="@array/optimization_values"
            android:defaultValue="O2"
            app:iconSpaceReserved="false" />

        <MultiSelectListPreference
            android:key="compiler_target_arch"
            android:title="目标架构"
            android:summary="选择编译目标架构"
            android:entries="@array/target_arch_entries"
            android:entryValues="@array/target_arch_values"
            android:defaultValue="@array/target_arch_default"
            app:iconSpaceReserved="false" />

        <SeekBarPreference
            android:key="compiler_threads"
            android:title="编译线程数"
            android:summary="并行编译的线程数"
            android:defaultValue="2"
            android:min="1"
            android:max="8"
            app:showSeekBarValue="true"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            android:key="compiler_debug_symbols"
            android:title="保留调试信息"
            android:summary="在编译结果中保留调试符号"
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- 项目设置 -->
    <PreferenceCategory
        android:title="项目"
        android:icon="@android:drawable/ic_menu_save"
        app:iconSpaceReserved="false">

        <Preference
            android:key="project_default_path"
            android:title="默认项目路径"
            android:summary="选择项目默认保存位置"
            app:iconSpaceReserved="false" />

        <ListPreference
            android:key="project_auto_save"
            android:title="自动保存间隔"
            android:summary="文件自动保存的时间间隔"
            android:entries="@array/auto_save_entries"
            android:entryValues="@array/auto_save_values"
            android:defaultValue="60"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            android:key="project_backup"
            android:title="自动备份"
            android:summary="编译前自动备份项目文件"
            android:defaultValue="true"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- 外观设置 -->
    <PreferenceCategory
        android:title="外观"
        android:icon="@android:drawable/ic_menu_view"
        app:iconSpaceReserved="false">

        <ListPreference
            android:key="app_theme"
            android:title="应用主题"
            android:summary="选择应用整体主题"
            android:entries="@array/app_theme_entries"
            android:entryValues="@array/app_theme_values"
            android:defaultValue="dark"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            android:key="statusbar_immersive"
            android:title="沉浸式状态栏"
            android:summary="状态栏与应用主题融合"
            android:defaultValue="true"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- 关于 -->
    <PreferenceCategory
        android:title="关于"
        android:icon="@android:drawable/ic_menu_info_details"
        app:iconSpaceReserved="false">

        <Preference
            android:key="about_version"
            android:title="版本信息"
            android:summary="@string/app_name"
            app:iconSpaceReserved="false" />

        <Preference
            android:key="about_github"
            android:title="GitHub 项目"
            android:summary="在 GitHub 上查看源代码"
            app:iconSpaceReserved="false">
            <intent
                android:action="android.intent.action.VIEW"
                android:data="https://github.com/wuxianggujun/TinaIDE" />
        </Preference>

        <Preference
            android:key="about_licenses"
            android:title="开源许可"
            android:summary="查看第三方开源库许可"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

</androidx.preference.PreferenceScreen>
