; CMake language highlights (simplified)

; =======================================================================
; Commands
; =======================================================================

(normal_command (identifier) @function)

; =======================================================================
; Keywords
; =======================================================================

[
  "if"
  "elseif"
  "else"
  "endif"
  "foreach"
  "endforeach"
  "while"
  "endwhile"
  "function"
  "endfunction"
  "macro"
  "endmacro"
  "return"
  "break"
  "continue"
] @keyword

; =======================================================================
; Variables
; =======================================================================

(variable) @variable

; =======================================================================
; Strings
; =======================================================================

(quoted_argument) @string
(unquoted_argument) @string

; =======================================================================
; Comments
; =======================================================================

(line_comment) @comment
(bracket_comment) @comment

; =======================================================================
; Punctuation
; =======================================================================

["(" ")"] @punctuation.bracket
